# Copy this file to .env for local development. Never commit .env.

# Application
SERVER_PORT=8080
LOG_LEVEL=info

# MQTT / Meshtastic
# Set MQTT_ENABLED=false to run in manual-entry-only mode (no Meshtastic integration)
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_REGION=US
MQTT_CHANNEL_NUM=2
MQTT_CHANNEL_NAME=LongFast
MQTT_GATEWAY_NODE_ID=a3b4c5d6

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ares_bib_logger
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
