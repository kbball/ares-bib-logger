# Copy this file to .env for local development. Never commit .env.

# Application
SERVER_PORT=8080
LOG_LEVEL=info
# IANA timezone name for Winlink import/export time parsing (e.g. America/New_York, America/Chicago, America/Denver, America/Los_Angeles)
TIMEZONE=America/New_York

# MQTT / Meshtastic
# Set MQTT_ENABLED=false to run in manual-entry-only mode (no Meshtastic integration)
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_REGION=US
MQTT_CHANNEL_NUM=2
MQTT_CHANNEL_NAME=LongFast
# Index (0–7) of the bridged channel in the gateway's channel list.
# Used to set MeshPacket.channel on downlink messages so the firmware transmits on the correct channel.
# Check with 'meshtastic --info' or the Meshtastic app — primary channel is 0, secondary channels are 1+.
MQTT_CHANNEL_INDEX=0
MQTT_GATEWAY_NODE_ID=a3b4c5d6

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ares_bib_logger
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
